{
  "dashboard": {
    "title": "Container Logs Dashboard",
    "uid": "container-logs",
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 0,
    "refresh": "5s",
    "panels": [
      {
        "title": "All Container Logs",
        "type": "logs",
        "datasource": "Loki",
        "targets": [
          {
            "expr": "{container_name=~\".+\"}",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 12,
          "w": 24,
          "x": 0,
          "y": 0
        }
      },
      {
        "title": "Backend Logs",
        "type": "logs",
        "datasource": "Loki",
        "targets": [
          {
            "expr": "{container_name=\"todo-backend\"}",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 12
        }
      },
      {
        "title": "Database Logs",
        "type": "logs",
        "datasource": "Loki",
        "targets": [
          {
            "expr": "{container_name=\"todo-database\"}",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 12
        }
      },
      {
        "title": "Error Logs (All Containers)",
        "type": "logs",
        "datasource": "Loki",
        "targets": [
          {
            "expr": "{container_name=~\".+\"} |~ \"(?i)error|exception|fatal|critical\"",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 20
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"]
    }
  }
}
